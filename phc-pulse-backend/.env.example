# Ye file copy karke naam ".env" rakho aur apni real values daalo

# PostgreSQL connection - format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/phc_pulse

# JWT secret - koi bhi random long string daal do (production me strong random string use karo)
SECRET_KEY=change-this-to-a-long-random-secret-string

# Gemini API key - https://ai.google.dev/gemini-api/docs/api-key se free me milegi
GEMINI_API_KEY=your-gemini-api-key-here
